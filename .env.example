# Deployer / principal A (pool admin + seat A controller)
PRIVATE_KEY=0xYOUR_64_HEX_CHARS

# Principal B (independent signer for red-team two-principal demo)
PRINCIPAL_B_PRIVATE_KEY=0xYOUR_64_HEX_CHARS

# Monad testnet (https://docs.monad.xyz/developer-essentials/testnets)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER=https://testnet.monadvision.com

# Filled after D2 deploy
FLEETLEDGER=0x

# Human labels (hashed to bytes32) or 0x-prefixed bytes32
POOL_ID=fleetmeter-spark
SEAT_ID=seat-principal-a
SEAT_B_ID=seat-principal-b

# Optional: JSON quota file instead of quota-axi
# FLEETMETER_QUOTA_FILE=./cli/examples/quota.json
